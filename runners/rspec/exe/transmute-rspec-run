#!/usr/bin/env ruby
# frozen_string_literal: true

require 'json'
require 'socket'

DEFAULT_SOCKET = '/tmp/transmute-rspec.sock'

socket_path = ENV['TRANSMUTE_RSPEC_SOCKET'] || DEFAULT_SOCKET
spec_path = ARGV[0]

if spec_path.nil? || spec_path.empty?
  warn 'usage: transmute-rspec-run <spec_file>'
  exit 2
end

open_socket =
  if socket_path.start_with?('tcp://')
    host_port = socket_path.sub(%r{^tcp://}, '')
    host, port = host_port.split(':')
    ->(&block) { TCPSocket.open(host, Integer(port), &block) }
  else
    ->(&block) { UNIXSocket.open(socket_path, &block) }
  end

begin
  open_socket.call do |sock|
    sock.puts(JSON.generate({ action: 'run', spec: spec_path }))
    line = sock.gets
    if line.nil? || line.empty?
      warn "transmute-rspec-run: daemon at #{socket_path} closed the connection without responding"
      exit 2
    end

    response = JSON.parse(line)
    $stdout.write(response['stdout'].to_s)
    exit Integer(response['exit_code'] || 2)
  end
rescue Errno::ENOENT, Errno::ECONNREFUSED
  warn "transmute-rspec-run: daemon not reachable at #{socket_path}; start it with 'bundle exec transmute-rspec serve'"
  exit 2
end
